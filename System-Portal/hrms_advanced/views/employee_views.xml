<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_hrms_employee" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hrms.employee</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first employee</p>
        </field>
    </record>
    <record id="view_hrms_employee_tree" model="ir.ui.view">
        <field name="name">hrms.employee.tree</field>
        <field name="model">hrms.employee</field>
        <field name="arch" type="xml">
            <tree>
                <field name="employee_id"/>
                <field name="name"/>
                <field name="email"/>
                <field name="department"/>
                <field name="job_title"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
    <record id="view_hrms_employee_form" model="ir.ui.view">
        <field name="name">hrms.employee.form</field>
        <field name="model">hrms.employee</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_row">
                        <div class="oe_span12">
                            <field name="image_1920" class="oe_avatar"/>
                            <div class="oe_title">
                                <h1><field name="name" placeholder="Full Name"/></h1>
                                <h3><field name="employee_id"/></h3>
                            </div>
                        </div>
                    </div>
                    <group>
                        <group string="Contact Info">
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="street" placeholder="Street..."/>
                            <field name="city"/>
                            <field name="state"/>
                            <field name="zip"/>
                            <field name="country_id"/>
                        </group>
                        <group string="Professional Info">
                            <field name="department"/>
                            <field name="job_title"/>
                            <field name="user_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="salary" widget="monetary"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_hrms_employee_search" model="ir.ui.view">
        <field name="name">hrms.employee.search</field>
        <field name="model">hrms.employee</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="email"/>
                <field name="department"/>
                <filter string="Active" name="active_filter" domain="[('active','=',True)]"/>
                <filter string="Inactive" name="inactive_filter" domain="[('active','=',False)]"/>
                <group expand="1" string="Group By">
                    <filter string="Department" name="group_department" context="{'group_by':'department'}"/>
                    <filter string="Job Title" name="group_job" context="{'group_by':'job_title'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
