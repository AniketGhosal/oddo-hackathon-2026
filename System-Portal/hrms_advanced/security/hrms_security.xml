<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_hrms" model="ir.module.category">
        <field name="name">HRMS</field>
        <field name="description">Human Resource Management System</field>
    </record>
    <record id="group_hrms_employee" model="res.groups">
        <field name="name">Employee</field>
        <field name="category_id" ref="module_category_hrms"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_hrms_manager" model="res.groups">
        <field name="name">HR / Admin</field>
        <field name="category_id" ref="module_category_hrms"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_hrms_employee_own" model="ir.rule">
        <field name="name">Employee: Own Record</field>
        <field name="model_id" ref="model_hrms_employee"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_hrms_employee'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="rule_hrms_employee_manager" model="ir.rule">
        <field name="name">Manager: All Records</field>
        <field name="model_id" ref="model_hrms_employee"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_hrms_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
